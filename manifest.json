{
  "manifest_version": 3,
  "name": "Prospectoo - YouTube Channel Analyzer & Email Finder",
  "version": "1.0.0",
  "description": "AI-powered YouTube channel analyzer to find similar channels, extract emails, and get real-time insights",
  
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "unlimitedStorage"
  ],
  
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.googleapis.com/*",
    "https://*.prospectoo.com/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Prospectoo - YouTube Channel Analyzer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "icons/*"],
      "matches": ["https://*.youtube.com/*"]
    }
  ]
}