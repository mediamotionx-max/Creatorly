# Prospectoo Backend Environment Configuration

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=text-embedding-3-small

# YouTube Data API (Optional)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development
API_VERSION=v1

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Cache Configuration
CACHE_TTL_MS=300000
REDIS_URL=redis://localhost:6379
USE_REDIS_CACHE=false

# Database Configuration (Optional)
MONGODB_URI=mongodb://localhost:27017/prospectoo
DATABASE_NAME=prospectoo

# Security Configuration
JWT_SECRET=your_jwt_secret_key_here
BCRYPT_ROUNDS=12
CORS_ORIGIN=chrome-extension://*,http://localhost:*

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/prospectoo.log

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Analytics Configuration
GOOGLE_ANALYTICS_ID=your_ga_id_here
MIXPANEL_TOKEN=your_mixpanel_token_here

# Feature Flags
ENABLE_EMAIL_EXTRACTION=true
ENABLE_REAL_TIME_SCANNING=true
ENABLE_ANALYTICS=true
ENABLE_CACHING=true

# Performance Configuration
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT_MS=30000
MAX_RESULTS_LIMIT=100
SIMILARITY_THRESHOLD=0.7

# Development Configuration
DEBUG=prospectoo:*
ENABLE_SWAGGER=true
ENABLE_MORGAN_LOGGING=true